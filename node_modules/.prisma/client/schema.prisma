generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  businesses Business[]
}

model Business {
  id      String @id @default(uuid())
  ownerId String
  name    String
  slug    String @unique
  city    String

  owner    User      @relation(fields: [ownerId], references: [id])
  services Service[]
}

model Service {
  id         String @id @default(uuid())
  businessId String
  name       String
  duration   Int

  business Business @relation(fields: [businessId], references: [id])
}
