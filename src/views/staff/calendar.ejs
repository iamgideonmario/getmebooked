<h1 class="text-xl font-bold mb-4">My Calendar</h1>

<div class="space-y-3">
  <% bookings.forEach(b => { %>
    <div class="p-3 bg-white shadow rounded">
      <p><strong>Date:</strong> <%= b.startUtc.toDateString() %></p>
      <p><strong>Time:</strong> <%= b.startUtc.toLocaleTimeString() %></p>
    </div>
  <% }) %>
</div>
